TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
AI_API_KEY=your_openai_api_key_here

# Optional overrides (defaults are applied if omitted)
OPENAI_MODEL=gpt-4o-mini
ACTION_PLANNER_ENABLED=true
ACTION_PLANNER_LEGACY_FALLBACK=false
MEMORY_EXTRACTION_ENABLED=false
DATABASE_PATH=./data/bot.sqlite
APP_TIMEZONE=Asia/Jerusalem
SCHEDULER_INTERVAL_SECONDS=20
NEWS_SCHEDULER_INTERVAL_SECONDS=60
NEWS_FETCH_TIMEOUT_MS=8000
NEWS_MAX_ITEMS=5
MEMORY_MESSAGE_LIMIT=6
OPENAI_TIMEOUT_MS=15000
